# Copy to .env and fill in. Never commit the real .env.

# Anthropic API key — powers the "Which Animal Are You?" quiz (/api/quiz).
# Get it at: https://platform.claude.com → API keys. Set this in your Vercel
# project's Environment Variables too (Production + Preview). Server-side only —
# never exposed to the browser.
ANTHROPIC_API_KEY=

# Kit (ConvertKit) API key — used by `npm run notify` to broadcast new posts.
# Get it at: Kit → Settings → Advanced → API (v4 key).
KIT_API_KEY=

# Canonical site URL (used by the notify script for post links).
SITE_URL=https://hoofandclaw.org
