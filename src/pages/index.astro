---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Newsletter from '../components/Newsletter.astro';
import { site } from '../config';

import emblem from '../assets/emblem.png';
import herdBanner from '../assets/factions/herd.png';
import packBanner from '../assets/factions/pack.png';
import chaosBanner from '../assets/factions/chaos.png';

// Atmospheric gallery — evocative captions only, no rules.
import gGrazing from '../assets/gallery/Grazing.png';
import gWatch from '../assets/gallery/WatchfulEye.png';
import gPanther from '../assets/gallery/PantherHunt.png';
import gPack from '../assets/gallery/PackHunt.png';
import gCroc from '../assets/gallery/CrocodileHunt.png';
import gStampede from '../assets/gallery/Stampede.png';
import gToll from '../assets/gallery/MorningToll.png';
import gHerdWin from '../assets/gallery/HerdVictory.png';
import gPackWin from '../assets/gallery/PackVictory.png';
import gMamba from '../assets/gallery/BlackmambaVictory.png';
import gHome from '../assets/gallery/HomeScreen.png';
import gMonkey from '../assets/gallery/MonkeyJoinGameScreen.png';
import gMist from '../assets/gallery/Grazing-MorningMistFate.png';
import gDrought from '../assets/gallery/Grazing-DraughtFate.png';
import gBushfire from '../assets/gallery/Stampede-BushfireFate.png';
import gLush from '../assets/gallery/Stampede-LushgrazingFate.png';
import gMonsoon from '../assets/gallery/PackHunt-MonsoonRainFate.png';
import gEclipse from '../assets/gallery/PachHunt-MidnightEclipseFate.png';
import gShiftHerd from '../assets/gallery/EnvironmentalShift-FavorHerd.png';
import gShiftPack from '../assets/gallery/EnvironmentalShift-FavorsPack.png';
import gShiftNone from '../assets/gallery/EnvironmentalShift-NoCards.png';
import gMambaVenom from '../assets/gallery/MambaVenom.png';
import gVultureTrig from '../assets/gallery/VultureFeastTrigger.png';
import gVultureWin from '../assets/gallery/VultureVictory.png';
import gCrocWin from '../assets/gallery/CrocodileVictory.png';
import gBone from '../assets/gallery/BonePicker.png';
import gTollMany from '../assets/gallery/MorningToll-MultipleDead.png';
import gAftermath from '../assets/gallery/Aftermath.png';

const gallery = [
  { src: gHome, cap: 'Hoof & Claw' },
  { src: gMonkey, cap: 'The watcher on the rock' },
  { src: gGrazing, cap: 'First light' },
  { src: gWatch, cap: 'Something watches' },
  { src: gStampede, cap: 'The reckoning' },
  { src: gPanther, cap: 'From the shadows' },
  { src: gPack, cap: 'The pack closes in' },
  { src: gCroc, cap: 'Still waters' },
  { src: gToll, cap: 'Dawn counts its dead' },
  { src: gHerdWin, cap: 'Those who endured' },
  { src: gPackWin, cap: 'The night wins' },
  { src: gMamba, cap: "Venom's patience" },
  // The rest of the savanna, following Venom's patience.
  { src: gMambaVenom, cap: "The serpent's gift" },
  { src: gMist, cap: 'Morning mist' },
  { src: gDrought, cap: 'The long drought' },
  { src: gBushfire, cap: 'Bushfire' },
  { src: gLush, cap: 'Green abundance' },
  { src: gMonsoon, cap: 'Through the monsoon' },
  { src: gEclipse, cap: 'Under the eclipse' },
  { src: gShiftHerd, cap: 'The land favors the many' },
  { src: gShiftPack, cap: 'The land favors the fangs' },
  { src: gShiftNone, cap: 'An indifferent sky' },
  { src: gVultureTrig, cap: 'The vultures gather' },
  { src: gVultureWin, cap: 'The patient scavenger' },
  { src: gCrocWin, cap: 'The river always wins' },
  { src: gBone, cap: 'The bone-pickers' },
  { src: gTollMany, cap: 'A heavy dawn' },
  { src: gAftermath, cap: 'When the dust settles' },
];
---

<Base>
  <!-- Sticky top nav -->
  <header class="nav">
    <a href="/" class="nav__brand display">Hoof &amp; Claw</a>
    <nav class="nav__links">
      <a href="#herd">The Herd</a>
      <a href="#pack">The Pack</a>
      <a href="#chaos">Chaos</a>
      <a href="/blog">Dev log</a>
      <a href="#waitlist" class="nav__cta">Join the waitlist</a>
    </nav>
  </header>

  <main>
    <!-- ===================== HERO ===================== -->
    <section class="hero">
      <div class="emblem-float">
        <div class="emblem-wrap" data-tilt>
          <Image
            src={emblem}
            alt="Hoof &amp; Claw"
            class="emblem"
            widths={[280, 420, 560, 720]}
            sizes="(max-width: 640px) 70vw, 32rem"
            loading="eager"
          />
          <span class="emblem-sheen" aria-hidden="true"></span>
        </div>
      </div>

      <p class="hero__tagline narration">{site.tagline}</p>

      <p class="hero__positioning">{site.positioning}</p>

      <div class="hero__lore">
        <p>{site.intro.body}</p>
        <p class="hero__flourish narration">{site.intro.flourish}</p>
      </div>

      <div class="hero__cta">
        <a href="#waitlist" class="btn btn--primary">Join the waitlist</a>
        <a href="#herd" class="btn btn--ghost">Enter the savanna</a>
      </div>

      <a href="#herd" class="hero__scroll" aria-label="Scroll down">
        <span>descend into dawn</span><span class="hero__chev">⌄</span>
      </a>
    </section>

    <!-- ===================== ACT I — THE HERD (Dawn / Hope) ===================== -->
    <section id="herd" class="act act--herd">
      <div class="act__art">
        <Image src={herdBanner} alt="The Herd — banner" widths={[220, 340, 460]} sizes="18rem" />
      </div>
      <div class="act__body">
        <p class="act__phase">Dawn · Hope</p>
        <h2 class="act__name display">The Herd</h2>
        <p class="act__copy">
          When the sun crests the acacia, the many gather in the open — grazing,
          laughing, certain of the friends beside them. Their only strength is
          one another. Their only hope is to tell <em>friend</em> from
          <em>fang</em> before the light fails.
        </p>
      </div>
    </section>

    <!-- ===================== ACT II — THE PACK (Dusk / The Hunt) ===================== -->
    <section id="pack" class="act act--pack act--reverse">
      <div class="act__art">
        <Image src={packBanner} alt="The Pack — banner" widths={[220, 340, 460]} sizes="18rem" />
      </div>
      <div class="act__body">
        <p class="act__phase">Dusk · Fear</p>
        <h2 class="act__name display">The Pack</h2>
        <p class="act__copy">
          The sky bleeds red and the herd's laughter thins. Hunters wear familiar
          faces — patient, coordinated, already counting who will not see the
          dawn. By dusk, every smile hides a question: <em>whose teeth are
          those?</em>
        </p>
      </div>
    </section>

    <!-- ===================== ACT III — CHAOS (Night / Betrayal) ===================== -->
    <section id="chaos" class="act act--chaos">
      <div class="act__art">
        <Image src={chaosBanner} alt="Chaos — banner" widths={[220, 340, 460]} sizes="18rem" />
      </div>
      <div class="act__body">
        <p class="act__phase">Night · Betrayal</p>
        <h2 class="act__name display">Chaos</h2>
        <p class="act__copy">
          Then the dark closes over everything. Some at the table answer to
          neither herd nor pack — they play a game all their own, and the savanna
          bends to whoever is still standing when the long night ends. Trust no
          one. Least of all the quiet ones.
        </p>
      </div>
    </section>

    <!-- ===================== WHAT IT IS ===================== -->
    <section class="band band--center">
      <h2 class="band__title display">A board game that comes alive on your table</h2>
      <p class="band__sub">
        Hoof &amp; Claw pairs a beautifully illustrated board game with a companion
        app that runs the night for you — so every gathering becomes a story of
        alliances, suspicion, and the friend who fooled everyone. Easy to learn.
        Impossible to trust.
      </p>
      <ul class="stats stats--wide" aria-label="At a glance">
        {
          site.stats.map((s) => (
            <li class="stat">
              <span class="stat__value display">{s.value}</span>
              <span class="stat__label">{s.label}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- ===================== GALLERY ===================== -->
    <section class="gallery">
      <h2 class="band__title display">Glimpses of the savanna</h2>
      <p class="band__sub">Scroll the world of Hoof &amp; Claw — tap any piece to linger.</p>
      <div class="filmstrip" data-gallery>
        {
          gallery.map((g, i) => (
            <button class="frame" data-index={i} aria-label={`View: ${g.cap}`}>
              <Image src={g.src} alt={g.cap} widths={[280, 420, 640]} sizes="20rem" />
              <span class="frame__cap narration">{g.cap}</span>
            </button>
          ))
        }
      </div>
    </section>

    <!-- ===================== WAITLIST ===================== -->
    <section id="waitlist" class="band band--cta">
      <p class="cta__eyebrow narration">The long night is coming.</p>
      <h2 class="band__title display">Be there when the Pack stirs</h2>
      <p class="band__sub">
        Hoof &amp; Claw is heading to Kickstarter. Join the waitlist for behind-the-scenes
        dev updates, early-backer perks, and launch-day access.
      </p>
      <div class="cta__form"><Newsletter variant="hero" /></div>
    </section>
  </main>

  <footer class="footer">
    <p class="footer__brand display">Hoof &amp; Claw</p>
    <nav class="footer__links">
      <a href="/blog">Dev log</a>
      {site.links.kickstarter && <a href={site.links.kickstarter}>Kickstarter</a>}
      {site.links.discord && <a href={site.links.discord}>Discord</a>}
      {site.links.instagram && <a href={site.links.instagram}>Instagram</a>}
      {site.links.bgg && <a href={site.links.bgg}>BoardGameGeek</a>}
    </nav>
    <p class="footer__fine">© {new Date().getFullYear()} {site.name}. Made on the savanna.</p>
  </footer>

  <!-- Lightbox -->
  <dialog class="lightbox" data-lightbox>
    <button class="lightbox__close" data-lightbox-close aria-label="Close">✕</button>
    <img class="lightbox__img" data-lightbox-img alt="" />
    <p class="lightbox__cap narration" data-lightbox-cap></p>
  </dialog>
</Base>

<style>
  /* ---------- nav ---------- */
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem clamp(1rem, 4vw, 3rem);
    backdrop-filter: blur(8px);
    background: linear-gradient(180deg, rgba(7, 6, 12, 0.6), rgba(7, 6, 12, 0));
  }
  .nav__brand { font-size: 1.25rem; font-weight: 700; color: var(--color-gold-light); text-decoration: none; }
  .nav__links { display: flex; gap: clamp(0.75rem, 2vw, 1.75rem); align-items: center; font-size: 0.95rem; }
  .nav__links a { color: var(--color-parchment); text-decoration: none; opacity: 0.85; }
  .nav__links a:hover { opacity: 1; }
  .nav__cta { padding: 0.45rem 0.9rem; border-radius: 0.6rem; border: 1px solid rgba(201, 162, 39, 0.5); color: var(--color-gold-light) !important; }
  @media (max-width: 640px) { .nav__links a:not(.nav__cta) { display: none; } }

  main { position: relative; z-index: 1; }
  section { padding: clamp(3rem, 9vw, 7rem) clamp(1.25rem, 6vw, 4rem); }

  /* ---------- hero / emblem ---------- */
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.25rem;
    perspective: 900px;
  }
  /* Outer layer: organic 3D drift (multi-axis, with depth pop) + glow pulse. */
  .emblem-float {
    width: min(52vw, 17rem);
    transform-style: preserve-3d;
    animation: emblem3d 13s ease-in-out infinite, emblemGlow 5.5s ease-in-out infinite;
  }
  @keyframes emblem3d {
    0%   { transform: rotateY(-7deg) rotateX(5deg) translateY(0) translateZ(0); }
    25%  { transform: rotateY(1deg) rotateX(7deg) translateY(-7px) translateZ(18px); }
    50%  { transform: rotateY(7deg) rotateX(3deg) translateY(-12px) translateZ(0); }
    75%  { transform: rotateY(0deg) rotateX(-3deg) translateY(-6px) translateZ(16px); }
    100% { transform: rotateY(-7deg) rotateX(5deg) translateY(0) translateZ(0); }
  }
  @keyframes emblemGlow {
    0%, 100% { filter: drop-shadow(0 26px 50px rgba(0, 0, 0, 0.6)) drop-shadow(0 0 26px rgba(201, 162, 39, 0.22)); }
    50% { filter: drop-shadow(0 34px 64px rgba(0, 0, 0, 0.7)) drop-shadow(0 0 52px rgba(232, 200, 74, 0.5)); }
  }
  /* Inner layer: pointer tilt composes on top of the idle drift. */
  .emblem-wrap {
    position: relative;
    transform-style: preserve-3d;
    transform: rotateX(var(--tx, 0deg)) rotateY(var(--ty, 0deg));
    transition: transform 0.2s ease-out;
  }
  .emblem { width: 100%; height: auto; display: block; }
  /* Automatic light-sweep across the gold — premium metallic shine. */
  .emblem-sheen {
    position: absolute;
    inset: -10%;
    background: linear-gradient(
      105deg,
      transparent 42%,
      rgba(255, 248, 220, 0) 45%,
      rgba(255, 248, 220, 0.8) 50%,
      rgba(255, 248, 220, 0) 55%,
      transparent 58%
    );
    mix-blend-mode: screen;
    opacity: 0;
    pointer-events: none;
    animation: sheen 6.5s ease-in-out 1.5s infinite;
  }
  @keyframes sheen {
    0% { transform: translateX(-120%); opacity: 0; }
    10% { opacity: 0.75; }
    24% { transform: translateX(120%); opacity: 0; }
    100% { transform: translateX(120%); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .emblem-float { animation: none; }
    .emblem-sheen { animation: none; }
  }
  @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }

  .hero__tagline {
    margin-top: 1.4rem;
    max-width: none;
    white-space: nowrap;
    font-size: clamp(0.7rem, 3.1vw, 1.95rem);
    line-height: 1.2;
    color: var(--color-gold-light);
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.75);
  }
  /* Refined, professional positioning line: gold-foil caps between hairlines. */
  /* Majestic-blue foil between gold hairlines; sized to wrap to ~2 lines. */
  .hero__positioning {
    margin: 1.4rem auto 0;
    max-width: 49rem;
    padding: 0.7rem 0;
    border-top: 1px solid rgba(201, 162, 39, 0.4);
    border-bottom: 1px solid rgba(201, 162, 39, 0.4);
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: clamp(0.76rem, 1.5vw, 1rem);
    line-height: 1.6;
    background: linear-gradient(180deg, #cfe0ff 0%, #6f9bff 45%, #355fe6 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter: drop-shadow(0 1px 7px rgba(0, 0, 0, 0.85));
  }
  .hero__lore {
    margin: 1.5rem auto 0;
    max-width: 52rem;
    color: var(--color-parchment);
    line-height: 1.7;
    font-size: clamp(0.92rem, 1.8vw, 1.06rem);
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.85);
  }
  .hero__lore p { margin: 0.7rem 0; }
  .hero__flourish {
    margin-top: 1.1rem;
    font-size: clamp(1.15rem, 2.8vw, 1.55rem);
    color: var(--color-gold-light);
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.8);
  }

  /* ---------- stats ---------- */
  .stats { list-style: none; display: flex; gap: clamp(1.25rem, 5vw, 3rem); margin: 1.75rem 0 0; padding: 0; }
  .stats--wide { margin-top: 2.5rem; justify-content: center; }
  .stat { display: flex; flex-direction: column; align-items: center; }
  .stat__value { font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 700; color: var(--color-gold-light); line-height: 1; }
  .stat__label { margin-top: 0.35rem; font-size: 0.8rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-parchment-muted); }

  .hero__cta { margin-top: 1.9rem; display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center; }
  .hero__scroll { margin-top: 2.2rem; display: flex; flex-direction: column; align-items: center; gap: 0.25rem; color: var(--color-parchment-muted); text-decoration: none; font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase; }
  .hero__chev { font-size: 1.4rem; animation: bob 1.8s ease-in-out infinite; }
  @keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(6px); } }

  /* ---------- buttons ---------- */
  .btn { display: inline-block; padding: 0.85rem 1.6rem; border-radius: 0.75rem; font-weight: 700; text-decoration: none; transition: transform 0.12s ease, box-shadow 0.12s ease; }
  .btn--primary { color: #1a1206; background: linear-gradient(180deg, var(--color-gold-light), var(--color-gold)); box-shadow: 0 10px 30px rgba(201, 162, 39, 0.4); }
  .btn--primary:hover { transform: translateY(-2px); box-shadow: 0 14px 40px rgba(201,162,39,.55); }
  .btn--ghost { color: var(--color-parchment); border: 1.5px solid rgba(245, 230, 200, 0.4); }
  .btn--ghost:hover { background: rgba(245,230,200,.12); }

  /* ---------- faction acts ---------- */
  .act {
    max-width: 64rem;
    margin: 0 auto;
    min-height: 86svh;
    display: grid;
    grid-template-columns: minmax(12rem, 18rem) 1fr;
    align-items: center;
    gap: clamp(1.5rem, 5vw, 4rem);
  }
  .act--reverse { direction: rtl; }
  .act--reverse > * { direction: ltr; }
  .act__art img { width: 100%; height: auto; display: block; filter: drop-shadow(0 18px 50px rgba(0,0,0,.6)); animation: float 8s ease-in-out infinite; }
  .act__phase { font-family: var(--font-display); font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; font-size: clamp(1.05rem, 2.6vw, 1.5rem); }
  .act__name { font-size: clamp(2.2rem, 6vw, 3.6rem); line-height: 1.05; margin-top: 0.3rem; }
  .act__copy { margin-top: 1rem; font-size: clamp(1.05rem, 2.4vw, 1.3rem); line-height: 1.65; color: var(--color-parchment); max-width: 34rem; text-shadow: 0 1px 14px rgba(0,0,0,.7); }
  .act__copy em { font-style: italic; color: var(--color-gold-light); }

  .act--herd .act__phase { color: var(--color-herd-light); }
  .act--herd .act__name { color: var(--color-herd-light); }
  .act--pack .act__phase { color: var(--color-pack-light); }
  .act--pack .act__name { color: var(--color-pack-light); }
  .act--chaos .act__phase { color: var(--color-chaos-teal); }
  .act--chaos .act__name { color: #d8dbe8; }

  @media (max-width: 720px) {
    .act { grid-template-columns: 1fr; text-align: center; min-height: auto; }
    .act--reverse { direction: ltr; }
    .act__art { max-width: 14rem; margin: 0 auto; }
    .act__copy { margin-inline: auto; }
  }

  /* ---------- bands ---------- */
  .band { max-width: 64rem; margin: 0 auto; }
  .band--center { text-align: center; max-width: 52rem; }
  .band__title { font-size: clamp(1.8rem, 4.5vw, 3rem); color: var(--color-gold-light); text-align: center; text-wrap: balance; text-shadow: 0 2px 18px rgba(0,0,0,.6); }
  .band__sub { margin: 1rem auto 0; max-width: 44rem; text-align: center; color: var(--color-parchment); line-height: 1.65; font-size: 1.1rem; text-shadow: 0 1px 12px rgba(0,0,0,.6); }

  /* ---------- gallery ---------- */
  .gallery { max-width: 84rem; margin: 0 auto; }
  .filmstrip {
    margin-top: 2.5rem;
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 1rem;
    scrollbar-width: thin;
  }
  .frame {
    position: relative;
    flex: 0 0 auto;
    width: clamp(13rem, 42vw, 19rem);
    aspect-ratio: 3 / 4;
    border: 1px solid rgba(201, 162, 39, 0.25);
    border-radius: 1rem;
    overflow: hidden;
    cursor: pointer;
    scroll-snap-align: center;
    background: #0a0a12;
    padding: 0;
    box-shadow: 0 16px 50px rgba(0, 0, 0, 0.5);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .frame:hover { transform: translateY(-4px); border-color: rgba(232, 200, 74, 0.7); }
  .frame img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .frame__cap {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 1.5rem 1rem 0.8rem;
    font-size: 1.1rem;
    color: var(--color-parchment);
    text-align: left;
    background: linear-gradient(180deg, transparent, rgba(5, 6, 12, 0.85));
  }

  /* ---------- cta ---------- */
  .band--cta { text-align: center; max-width: 48rem; margin: 0 auto; }
  .cta__eyebrow { color: var(--color-pack-light); font-size: 1.2rem; }
  .cta__form { margin-top: 2rem; display: flex; justify-content: center; }

  /* ---------- footer ---------- */
  .footer { position: relative; z-index: 1; text-align: center; padding: 3rem 1.5rem; border-top: 1px solid rgba(201,162,39,.15); background: rgba(3, 4, 10, 0.8); }
  .footer__brand { color: var(--color-gold-light); font-size: 1.2rem; }
  .footer__links { display: flex; gap: 1.25rem; justify-content: center; margin: 1rem 0; flex-wrap: wrap; }
  .footer__links a { color: var(--color-parchment); text-decoration: none; opacity: .8; }
  .footer__links a:hover { opacity: 1; }
  .footer__fine { color: rgba(196,169,106,.55); font-size: .8rem; }

  /* ---------- lightbox (full-viewport, image centered) ---------- */
  .lightbox {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100dvh;
    max-width: 100vw;
    max-height: 100dvh;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    overflow: hidden;
  }
  .lightbox[open] {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }
  .lightbox::backdrop { background: rgba(2, 3, 8, 0.9); backdrop-filter: blur(6px); }
  .lightbox__img {
    max-width: 92vw;
    max-height: 80vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 0.75rem;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.7);
    display: block;
  }
  .lightbox__cap { text-align: center; color: var(--color-gold-light); font-size: 1.3rem; margin: 0; }
  .lightbox__close { position: fixed; top: 1.25rem; right: 1.5rem; background: rgba(0,0,0,.5); color: #fff; border: 1px solid rgba(255,255,255,.3); border-radius: 999px; width: 2.6rem; height: 2.6rem; font-size: 1.1rem; cursor: pointer; z-index: 2; }
</style>

<script>
  // --- Emblem 3D tilt + sheen (pointer-driven; the "true 3D" accent) ---
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const tilt = document.querySelector<HTMLElement>('[data-tilt]');
  const hero = document.querySelector<HTMLElement>('.hero');
  if (tilt && hero && !reduce) {
    hero.addEventListener('pointermove', (e) => {
      const r = hero.getBoundingClientRect();
      const px = (e.clientX - r.left) / r.width - 0.5;
      const py = (e.clientY - r.top) / r.height - 0.5;
      tilt.style.setProperty('--ty', `${(px * 16).toFixed(2)}deg`);
      tilt.style.setProperty('--tx', `${(-py * 16).toFixed(2)}deg`);
      tilt.style.setProperty('--sheen', `${(px * 120).toFixed(0)}%`);
    });
    hero.addEventListener('pointerleave', () => {
      tilt.style.setProperty('--ty', '0deg');
      tilt.style.setProperty('--tx', '0deg');
    });
  }

  // --- Gallery lightbox ---
  const dialog = document.querySelector<HTMLDialogElement>('[data-lightbox]');
  const lbImg = document.querySelector<HTMLImageElement>('[data-lightbox-img]');
  const lbCap = document.querySelector<HTMLElement>('[data-lightbox-cap]');
  const frames = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-gallery] .frame'));
  frames.forEach((frame) => {
    frame.addEventListener('click', () => {
      const img = frame.querySelector('img');
      const cap = frame.querySelector('.frame__cap');
      if (dialog && lbImg && img) {
        lbImg.src = img.currentSrc || img.src;
        lbImg.alt = img.alt;
        if (lbCap) lbCap.textContent = cap?.textContent ?? '';
        dialog.showModal();
      }
    });
  });
  document.querySelector('[data-lightbox-close]')?.addEventListener('click', () => dialog?.close());
  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });
</script>
