---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base
  title="Dev Log - Hoof & Claw"
  description="Behind the scenes on Hoof & Claw: art drops, design notes, and the road to Kickstarter."
  sky={false}
>
  <header class="reading-nav">
    <a href="/" class="reading-nav__brand display">Hoof &amp; Claw</a>
    <a href="/#waitlist" class="reading-nav__cta">Join the waitlist</a>
  </header>

  <main class="wrap">
    <h1 class="page-title display">Dev Log</h1>
    <p class="page-sub">The road to the savanna - art, design notes, and playtest tales.</p>

    <ul class="posts">
      {
        posts.map((post) => (
          <li class="post">
            <a href={`/blog/${post.id}`} class="post__link">
              {post.data.cover && (
                <div class="post__cover">
                  <Image src={post.data.cover} alt={post.data.coverAlt ?? ''} widths={[320, 520]} sizes="22rem" />
                </div>
              )}
              <div class="post__meta">
                <span class="post__tag">{post.data.tag}</span>
                <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
              </div>
              <h2 class="post__title display">{post.data.title}</h2>
              <p class="post__desc">{post.data.description}</p>
              <span class="post__more">Read more →</span>
            </a>
          </li>
        ))
      }
      {posts.length === 0 && <li class="post post--empty">No posts yet - the savanna is quiet. For now.</li>}
    </ul>
  </main>

  <footer class="reading-foot">
    <a href="/">← Back to Hoof &amp; Claw</a>
    <a href="/rss.xml">RSS</a>
  </footer>
</Base>

<style>
  .reading-nav, .reading-foot {
    display: flex; align-items: center; justify-content: space-between;
    max-width: 50rem; margin: 0 auto; padding: 1.25rem clamp(1rem, 5vw, 2rem);
  }
  .reading-nav__brand { color: var(--color-gold-light); text-decoration: none; font-size: 1.2rem; }
  .reading-nav__cta { color: var(--color-gold-light); text-decoration: none; border: 1px solid rgba(201,162,39,.5); padding: .4rem .85rem; border-radius: .6rem; font-size: .9rem; }
  .wrap { max-width: 50rem; margin: 0 auto; padding: 1rem clamp(1rem, 5vw, 2rem) 4rem; }
  .page-title { font-size: clamp(2.2rem, 6vw, 3.2rem); color: var(--color-gold-light); }
  .page-sub { color: var(--color-parchment-muted); margin-top: .4rem; }
  .posts { list-style: none; padding: 0; margin: 2.5rem 0 0; display: grid; gap: 1.5rem; }
  .post { border: 1px solid rgba(201,162,39,.18); border-radius: 1rem; overflow: hidden; background: rgba(20,18,30,.5); transition: border-color .2s, transform .2s; }
  .post:hover { border-color: rgba(232,200,74,.55); transform: translateY(-3px); }
  .post__link { display: block; text-decoration: none; color: inherit; }
  .post__cover img { width: 100%; height: 12rem; object-fit: cover; display: block; }
  .post__meta { display: flex; gap: .75rem; align-items: center; padding: 1rem 1.25rem 0; font-size: .8rem; color: var(--color-parchment-muted); }
  .post__tag { color: var(--color-gold-light); letter-spacing: .08em; text-transform: uppercase; }
  .post__title { padding: .35rem 1.25rem 0; font-size: 1.5rem; color: var(--color-parchment); }
  .post__desc { padding: .5rem 1.25rem 0; color: var(--color-parchment-muted); line-height: 1.55; }
  .post__more { display: inline-block; padding: .75rem 1.25rem 1.25rem; color: var(--color-gold-light); font-weight: 700; }
  .post--empty { padding: 2rem; text-align: center; color: var(--color-parchment-muted); }
  .reading-foot a { color: var(--color-parchment-muted); text-decoration: none; }
  .reading-foot a:hover { color: var(--color-gold-light); }
</style>
